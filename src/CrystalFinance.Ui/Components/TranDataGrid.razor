@using System.Net.Http.Json
@inject ISnackbar Snackbar

<MudDataGrid @ref="_elementGrid"
             T="TransactionModel"
             Items="@Transactions"
             ReadOnly="false"
             EditMode="DataGridEditMode.Cell"
             Bordered="true"
             Dense="true"
             CommittedItemChanges="@CommittedItemChanges">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Review Transactions</MudText>
        <MudSpacer />
        @* Simplified Add: Manual entries for missing transactions *@
        <MudButton OnClick="NewItemAsync"
                   Variant="Variant.Filled"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Add">
            Add Manual Entry
        </MudButton>
    </ToolBarContent>
    <Columns>
        @* Map to your TrxDate property *@
        <PropertyColumn Property="x => x.TrxDate" Title="Date" Format="MM/dd/yyyy" />

        <PropertyColumn Property="x => x.Source" Title="Account" Editable="false" />

        <PropertyColumn Property="x => x.Description" Title="Description" />

        <PropertyColumn Property="x => x.Category" Title="Category" />

        @* Amount with Financial Alignment *@
        <PropertyColumn Property="x => x.Amount" Title="Amount">
            <EditTemplate>
                <MudNumericField @bind-Value="context.Item.Amount"
                                 Format="N2"
                                 T="decimal"
                                 HideSpinButtons="true" />
            </EditTemplate>
            <FooterTemplate>
                <div class="d-flex justify-end pt-2" style="font-weight:bold">
                    Total: @Transactions.Sum(x => x.Amount).ToString("C2")
                </div>
            </FooterTemplate>
        </PropertyColumn>

        @* Delete Action *@
        <TemplateColumn CellClass="d-flex justify-end">
            <CellTemplate>
                <MudIconButton Size="@Size.Small"
                               Icon="@Icons.Material.Outlined.Delete"
                               Color="Color.Error"
                               OnClick="@(() => DeleteItem(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    [Parameter] public List<TransactionModel> Transactions { get; set; } = new();

    private MudDataGrid<TransactionModel> _elementGrid = default!;

    // No longer fetching periodic table data. Data comes from FilePicker -> Parent -> This Parameter.
    protected override void OnInitialized()
    {
        // Initialization logic for the grid itself if needed
    }

    private void NewItemAsync()
    {
        // Source is required, so we provide a default for manual entries
        var elem = new TransactionModel { TrxDate = DateTime.Today, Source = "Manual" };
        Transactions.Insert(0, elem);
        StateHasChanged();
    }

    private void DeleteItem(TransactionModel item)
    {
        Transactions.Remove(item);
        StateHasChanged();
    }

    private Task CommittedItemChanges(TransactionModel item)
    {
        // You can add validation here, e.g., alerting if Amount is 0
        if (item.Amount == 0)
        {
            Snackbar.Add("Warning: Transaction amount is zero.", MudBlazor.Severity.Warning);
        }
        return Task.CompletedTask;
    }
}
