# Crystal Finance - Frontend Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Flask Application Settings
# ============================================================================

# Secret key for session encryption and CSRF protection
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_random_key_here

# Flask environment (development or production)
FLASK_ENV=development
FLASK_DEBUG=False

# Application port
PORT=5000

# ============================================================================
# Azure Entra ID (Microsoft Identity Platform) - MSAL Configuration
# Register your app at: https://portal.azure.com > Azure Entra ID > App registrations
# ============================================================================

# Your application's client ID from Azure Entra ID app registration
CLIENT_ID=your_app_client_id_here

# Your application's client secret (keep this secret!)
# Create in: App registration > Certificates & secrets > New client secret
CLIENT_SECRET=your_app_client_secret_here

# Azure AD tenant ID or 'common' for multi-tenant
# Found in: App registration > Overview > Directory (tenant) ID
AZURE_TENANT=common

# Authority endpoint for token acquisition
# Default: https://login.microsoftonline.com/{AZURE_TENANT}
AUTHORITY=https://login.microsoftonline.com/common

# Redirect URI after authentication (must match registered redirect URI in Azure AD)
# Format: http://{host}:{port}/getAToken
REDIRECT_URI=http://localhost:5000/getAToken

# API scope(s) for the backend API
# Usually: api://{API_CLIENT_ID}/.default
# Or multiple scopes separated by spaces: scope1 scope2 scope3
API_SCOPE=

# ============================================================================
# C# Web API Backend Configuration
# ============================================================================

# Base URL of the C# Web API backend
# Make sure the API is running on this address
API_BASE_URL=http://localhost:5001

# Timeout for API requests (in seconds)
API_TIMEOUT=30

# ============================================================================
# Database Configuration
# NOTE: Database access is now through the C# Web API
# The API connects to MySQL database (no direct SQLite)
# ============================================================================

# This is kept for reference only - not used in the refactored Flask app
# The C# API backend handles all database operations
DATABASE=transactions.db

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================

# 1. MSAL Authentication Flow:
#    - User visits Flask app
#    - Flask redirects to Azure AD login page
#    - After authentication, Azure AD redirects to REDIRECT_URI with authorization code
#    - Flask exchanges code for access tokens
#    - Access token is used to call the C# Web API

# 2. API Communication:
#    - Flask frontend receives requests from browser
#    - Flask uses access token from MSAL to authenticate with C# Web API
#    - C# API validates the token and returns data from MySQL database
#    - Flask formats data for browser response

# 3. C# Web API Endpoints:
#    - GET  /api/CrystalFinance (get transactions with pagination)
#    - GET  /api/CrystalFinance/{id} (get single transaction)
#    - POST /api/CrystalFinance (create transaction)
#    - PUT  /api/CrystalFinance/{id} (update transaction)
#    - DELETE /api/CrystalFinance/{id} (delete transaction)
#    - POST /api/transactions/import (bulk import)

# 4. Required Python Packages (see requirements.txt):
#    - flask: Web framework
#    - flask-session: Session management
#    - flask-wtf: CSRF protection
#    - msal: Microsoft authentication
#    - requests: HTTP client for API calls
#    - python-dotenv: Environment variable loading
#    - gunicorn: Production WSGI server

# ============================================================================
# Setup Instructions
# ============================================================================

# 1. Install Python dependencies:
#    pip install -r requirements.txt

# 2. Create .env file:
#    cp .env.example .env
#    Edit .env with your Azure AD credentials and API settings

# 3. Ensure C# Web API is running:
#    The API should be accessible at API_BASE_URL (default: http://localhost:5001)

# 4. Run Flask development server:
#    python -m flask run

# 5. Access the application:
#    Open browser to http://localhost:5000

# ============================================================================
# Docker Deployment
# ============================================================================

# For Docker, set environment variables when running the container:
# docker run -e CLIENT_ID=xxx -e CLIENT_SECRET=yyy -e API_BASE_URL=http://api:5001 crystal-finance-frontend
