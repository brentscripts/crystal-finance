# ============================================================================
# Crystal Finance - Unified Monorepo Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# 1. MySQL Database (Container: mysql)
# ----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=finance
MYSQL_USER=financeuser
MYSQL_PASSWORD=nk$+Pr@1$3+2+Th3+L0rd!

# Host port mapping (Using 3307 as seen in your Docker Desktop)
HOST_PORT=3307

# ----------------------------------------------------------------------------
# 2. Azure Entra ID (MSAL Configuration)
# ----------------------------------------------------------------------------
CLIENT_ID=your_app_client_id_here
CLIENT_SECRET=your_app_client_secret_here
AZURE_TENANT=common
AUTHORITY=https://microsoftonline.com
# Must match your Azure App Registration redirect URI
REDIRECT_URI=http://localhost:5000/getAToken

# ----------------------------------------------------------------------------
# 3. Flask Frontend (Container: flask-ui)
# ----------------------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True
# Generate via: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_random_key_here

# Internal Docker URL for Flask to talk to the C# API
# Inside Docker network, use the service name 'web-api'
API_BASE_URL=http://web-api:8080
API_TIMEOUT=120
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# 4. Web API (Container: web-api)
# ----------------------------------------------------------------------------
# The API port inside the container
API_INTERNAL_PORT=8080
# The API port exposed to your PC
API_HOST_PORT=8080

# ----------------------------------------------------------------------------
# 5. Notebook / Local Dev Settings
# ----------------------------------------------------------------------------
# Use these when running the .ipynb on your PC (outside Docker)
# LOCAL_DB_URL=mysql+pymysql://financeuser:password@localhost:3307/finance
# LOCAL_API_URL=http://localhost:8080

